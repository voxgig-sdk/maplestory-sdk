            "{version}"
            "chat"
          ]
          select: {
            exist: [
              "message"
              "region"
              "ring_ids_joined"
              "version"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }

  relations: {
    ancestors: [
      [
        "api"
      ]
    ]
  }



}
