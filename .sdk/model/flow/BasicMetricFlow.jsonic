  name: "BasicMetricFlow",
  step: [
    {
      input: {
        ref: "metric_ref01",
        srcdatavar: "metric_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-metric_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicMetricFlow"
}